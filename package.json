{
  "name": "playback-mcp",
  "private": true,
  "license": "MIT",
  "author": "Blaise Moses <bamoses2001@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BlaiseMoses01/playback-mcp.git"
  },
  "homepage": "https://github.com/BlaiseMoses01/playback-mcp#readme",
  "bugs": "https://github.com/BlaiseMoses01/playback-mcp/issues",
  "type": "module",
  "workspaces": [
    "server",
    "extension"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit -p server/tsconfig.json && tsc -p extension/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky",
    "smoke": "node scripts/mcp-poke.mjs"
  },
  "lint-staged": {
    "*.{ts,js,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.0.0",
    "globals": "^15.14.0",
    "husky": "^9.1.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^4.1.8"
  }
}
