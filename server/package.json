{
  "name": "yt-controller-mcp",
  "version": "0.1.0",
  "description": "MCP server that controls YouTube playback in your browser via the YT Controller extension — play, seek, loop sections, save timestamps, build a video library",
  "license": "MIT",
  "type": "module",
  "bin": {
    "yt-controller-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=23.4"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "youtube",
    "playback",
    "loop",
    "claude",
    "chrome-extension"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "ws": "^8.18.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.6.0"
  }
}
