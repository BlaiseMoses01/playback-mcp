{
  "name": "playback-mcp",
  "version": "0.2.1",
  "description": "MCP server that controls YouTube playback in your browser via the Playback MCP extension — play, seek, loop sections, save timestamps, build a video library",
  "license": "MIT",
  "author": "Blaise Moses <bamoses2001@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BlaiseMoses01/playback-mcp.git",
    "directory": "server"
  },
  "homepage": "https://github.com/BlaiseMoses01/playback-mcp#readme",
  "bugs": "https://github.com/BlaiseMoses01/playback-mcp/issues",
  "type": "module",
  "bin": {
    "playback-mcp": "dist/index.js",
    "playback-mcp-broker": "dist/broker.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=23.4"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build && cp ../README.md ../LICENSE ."
  },
  "keywords": [
    "mcp",
    "youtube",
    "playback",
    "loop",
    "claude",
    "chrome-extension"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "ws": "^8.18.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/ws": "^8.5.0",
    "typescript": "^6.0.3"
  }
}
