{
  "manifest_version": 3,
  "name": "Playback MCP",
  "version": "0.2.2",
  "description": "Control YouTube playback from local AI agents and MCP-compatible tools like Claude Code, Codex, etc.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Playback MCP",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["tabs", "storage", "alarms"],
  "host_permissions": ["*://www.youtube.com/*"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
